# Portal Guru Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# AI Services
# The client ONLY uses the proxy URL for legacy routes.
VITE_OPENROUTER_PROXY_URL=https://your-domain.vercel.app/api/openrouter

# Backend AI Services (Supabase Edge Functions Secrets - DO NOT use VITE_ prefix)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-1.5-flash
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_MODELS=google/gemini-flash-1.5,openai/gpt-4o-mini
AI_REQUEST_TIMEOUT_MS=35000
AI_MAX_ATTEMPTS=4

# Required: restrict proxy to one or more comma-separated origins
OPENROUTER_ALLOWED_ORIGIN=https://your-domain.vercel.app

# Sentry Error Tracking (Optional)
VITE_SENTRY_DSN=https://your-sentry-dsn

# Feature Flags (Optional)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_FEATURES=false

# Web Push (VAPID)
# Generate keys once with:  npx web-push generate-vapid-keys
# Public key is exposed to the client. Private key stays server-side only.
VITE_VAPID_PUBLIC_KEY=

# Edge Function runtime secrets (configure in Supabase Dashboard, NOT .env):
#   VAPID_PUBLIC_KEY
#   VAPID_PRIVATE_KEY
#   VAPID_SUBJECT=mailto:admin@your-domain.com
#   APP_BASE_URL=https://your-domain.com

# Environment
VITE_APP_ENV=development
