    "@tanstack/react-query": "^5.51.1",
    "@tanstack/react-query-persist-client": "^5.100.13",
    "browser-image-compression": "^2.0.2",
    "canvas-confetti": "^1.9.4",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.7",
    "exceljs": "^4.4.0",
