{
  "name": "portal-guru",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test --config=playwright.functional.config.ts",
    "test:docs": "vitest run tests/docs-validation.test.ts tests/search-validation.test.ts tests/content-validation.test.ts tests/ci-docs-check.test.ts",
    "test:docs:watch": "vitest tests/docs-validation.test.ts tests/search-validation.test.ts tests/content-validation.test.ts tests/ci-docs-check.test.ts",
    "analyze": "cross-env ANALYZE=true vite build",
    "lighthouse": "lhci autorun --config=lighthouserc.cjs",
    "lint": "eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "docs:api": "typedoc",
    "docs:validate": "node scripts/validate-docs.cjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:all": "npm run docs:validate && npm run docs:api && npm run build-storybook",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "import:teachers": "node --env-file=.env scripts/import-teachers.js"
  },
  "dependencies": {
